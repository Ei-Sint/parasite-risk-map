('Coastal Range', 50.3755, -4.1427, 30.0, 'Sheep');  -- Plymouth area

INSERT INTO land_metadata (pasture_id, soil_type, is_marshy, elevation_meters)
VALUES 
(1, 'Clay', 1, 45),    -- High Risk: Clay holds water, marshy (Sheffield)
(2, 'Sandy', 0, 120),  -- Low Risk: Drains well, high elevation (Lancashire)
(3, 'Loam', 0, 85),    -- Medium Risk: Balanced soil (Bristol)
(4, 'Silt', 1, 30),    -- High Risk: Marshy, very low elevation (Birmingham)
(5, 'Peat', 0, 210);   -- Variable: High altitude (Plymouth)</sql><current_tab id="0"/></tab_sql></sqlb_project>
