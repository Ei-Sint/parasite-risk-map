8"/><column index="2" value="44"/><column index="3" value="58"/><column index="4" value="70"/><column index="5" value="135"/><column index="6" value="88"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="risk" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="21"/><column index="2" value="60"/><column index="3" value="77"/><column index="4" value="71"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="weather" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="21"/><column index="2" value="60"/><column index="3" value="89"/><column index="4" value="53"/><column index="5" value="88"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">CREATE TABLE farms (
  id INT AUTO_INCREMENT PRIMARY KEY,
  name VARCHAR(100),
  latitude DECIMAL(9,6),
  longitude DECIMAL(9,6)
);

CREATE TABLE weather (
  id INT AUTO_INCREMENT PRIMARY KEY,
  farm_id INT,
  temperature FLOAT,
  rainfall FLOAT,
  recorded_at DATETIME,
  FOREIGN KEY (farm_id) REFERENCES farms(id)
);

CREATE TABLE risk (
  id INT AUTO_INCREMENT PRIMARY KEY,
  farm_id INT,
  risk_score INT,
  risk_level VARCHAR(10),
  FOREIGN KEY (farm_id) REFERENCES farms(id)
);

INSERT INTO farms (id, name, latitude, longitude) VALUES
(1, 'Green Valley Farm', 53.381129, -1.470085),
(2, 'Sunny Acres', 53.390000, -1.480000),
(3, 'Riverdale Farm', 53.400000, -1.490000),
(4, 'Hilltop Farm', 53.410000, -1.500000),
(5, 'Oakwood Farm', 53.420000, -1.510000);

